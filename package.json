    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "dotenv": "^16.4.7",
    "jimp": "^1.6.1",
    "lucide-react": "^1.16.0",
    "nitro": "npm:nitro-nightly@^3.0.1-20260529-064703-255b254f",
