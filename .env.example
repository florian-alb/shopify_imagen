OPENAI_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2-2026-04-21
OPENAI_IMAGE_SIZE=1024x1024
OPENAI_IMAGE_QUALITY=medium
OPENAI_IMAGE_OUTPUT_FORMAT=jpeg
OPENAI_IMAGE_REQUESTS_PER_MINUTE=5
GENERATION_CONCURRENCY=1

GEMINI_API_KEY=
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview
GEMINI_IMAGE_REQUESTS_PER_MINUTE=5
# Optional. Output resolution: 1K, 2K, or 4K. Leave empty to keep the model default (1K).
GEMINI_IMAGE_SIZE=2K
# Optional. Output aspect ratio, e.g. 1:1, 4:3, 3:4, 16:9. Leave empty to keep the model default.
GEMINI_IMAGE_ASPECT_RATIO=1:1

SHOPIFY_SHOP_DOMAIN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-04
# Must also be listed in the app's allowed redirection URLs in Shopify.
# Defaults to ${CONVEX_SITE_URL}/shopify/oauth/callback when omitted.
SHOPIFY_OAUTH_REDIRECT_URL=
# Optional Shopify search query used during catalog sync.
SHOPIFY_PRODUCT_QUERY=status:active,draft,archived

